# Cloudflare API Configuration
# Get your API token from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone:Read, DNS:Edit, Pages:Edit
CLOUDFLARE_API_TOKEN=your_api_token_here

# Cloudflare Account ID (find it in the right sidebar of your Cloudflare dashboard)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Optional: DigitalPlat API key (if they provide API access in the future)
# DIGITALPLAT_API_KEY=your_digitalplat_api_key_here