# Netlify / Cloudflare Pages headers.
# NOTE: intentionally NO Cross-Origin-Embedder-Policy. The video tools use the
# ffmpeg.wasm SINGLE-THREAD core, which does not need SharedArrayBuffer / COOP-COEP.
# Enabling COEP would block the many third-party CDN libraries the other tools load.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), geolocation=(), microphone=(self)
  X-XSS-Protection: 0

/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable
